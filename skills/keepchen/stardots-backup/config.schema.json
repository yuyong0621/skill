{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Stardots Backup Configuration",
  "description": "Configuration for stardots.io image backup skill",
  "properties": {
    "apiKey": {
      "type": "string",
      "description": "Stardots API Key",
      "minLength": 1
    },
    "apiSecret": {
      "type": "string",
      "description": "Stardots API Secret",
      "minLength": 1
    },
    "space": {
      "type": "string",
      "description": "Target storage space name",
      "default": "default",
      "minLength": 4,
      "maxLength": 15
    }
  },
  "required": ["apiKey", "apiSecret", "space"]
}