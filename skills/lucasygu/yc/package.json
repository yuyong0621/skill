{
  "name": "@lucasygu/yc",
  "version": "0.3.1",
  "description": "CLI for YC Startup School, a16z Speedrun, South Park Commons & startup program discovery — from the terminal",
  "type": "module",
  "main": "./dist/lib/client.js",
  "exports": {
    ".": "./dist/lib/client.js",
    "./cookies": "./dist/lib/cookies.js"
  },
  "bin": {
    "yc": "dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "SKILL.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ycombinator",
    "yc",
    "startup-school",
    "a16z",
    "speedrun",
    "south-park-commons",
    "spc",
    "accelerator",
    "fellowship",
    "incubator",
    "discover",
    "cli",
    "claude-code",
    "claude-code-skill"
  ],
  "author": "lucasygu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasygu/yc-cli.git"
  },
  "bugs": {
    "url": "https://github.com/lucasygu/yc-cli/issues"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.1.0",
    "commander": "^13.1.0",
    "kleur": "^4.1.5",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
