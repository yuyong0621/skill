              "required": false,
              "defaultMatch": false
            }
          ]
        },
        "options": {}
      },
      "id": "n3",
      "name": "Log to Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        660,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "sendTo": "={{ $env.SHOPIFY_ADMIN_EMAIL || 'YOUR_NOTIFICATION_EMAIL' }}",
        "subject": "=New Order #{{ $json.order_number }} — {{ $json.currency }} {{ $json.total_price }}",
        "message": "=<h2>New Order Received</h2><table border='1' cellpadding='8' cellspacing='0'><tr><td><strong>Order</strong></td><td>#{{ $json.order_number }}</td></tr><tr><td><strong>Customer</strong></td><td>{{ $json.customer_name }}</td></tr><tr><td><strong>Email</strong></td><td>{{ $json.customer_email }}</td></tr><tr><td><strong>Total</strong></td><td>{{ $json.currency }} {{ $json.total_price }}</td></tr><tr><td><strong>Payment</strong></td><td>{{ $json.financial_status }}</td></tr><tr><td><strong>Items</strong></td><td>{{ $json.items_summary }}</td></tr><tr><td><strong>Shipping</strong></td><td>{{ $json.shipping_address }}</td></tr></table>",
        "options": {}
      },
      "id": "n4",
      "name": "Notify Admin",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        880,
        300
      ],
      "credentials": {
        "smtp": {
