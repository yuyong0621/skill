{
  "id": "latex-compiler",
  "name": "LaTeX Compiler",
  "version": "1.0.0",
  "description": "Compile LaTeX documents to PDF using pdflatex, xelatex, or lualatex. Includes template browsing and PDF preview.",
  "category": "latex",
  "author": "Prismer Team",
  "repository": "https://github.com/Prismer-AI/Prismer",
  "tools": [
    {
      "name": "latex_compile",
      "description": "Compile LaTeX source to PDF. Returns the container PDF path, log, errors, and warnings.",
      "parameters": {
        "content": {
          "type": "string",
          "description": "Full LaTeX source code to compile",
          "required": true
        },
        "filename": {
          "type": "string",
          "description": "Output filename stem (default: 'document')",
          "required": false,
          "default": "document"
        },
        "engine": {
          "type": "string",
          "description": "LaTeX engine to use",
          "required": false,
          "default": "pdflatex",
          "enum": ["pdflatex", "xelatex", "lualatex"]
        },
        "bibliography": {
          "type": "string",
          "description": "BibTeX/BibLaTeX bibliography content (triggers biber run)",
          "required": false
        },
        "runs": {
          "type": "number",
          "description": "Number of compilation passes (default: 2 for cross-references)",
          "required": false,
          "default": 2
        }
      }
    },
    {
      "name": "latex_preview",
      "description": "Compile LaTeX source and return the PDF as base64 for inline preview.",
      "parameters": {
        "content": {
          "type": "string",
          "description": "Full LaTeX source code to compile",
          "required": true
        },
        "filename": {
          "type": "string",
          "description": "Output filename stem (default: 'document')",
          "required": false,
          "default": "document"
        },
        "engine": {
          "type": "string",
          "description": "LaTeX engine to use",
          "required": false,
          "default": "pdflatex",
          "enum": ["pdflatex", "xelatex", "lualatex"]
        },
        "bibliography": {
          "type": "string",
          "description": "BibTeX/BibLaTeX bibliography content (triggers biber run)",
          "required": false
        }
      }
    },
    {
      "name": "latex_templates",
      "description": "List available LaTeX templates and supported engines",
      "parameters": {}
    },
    {
      "name": "latex_get_template",
      "description": "Get the LaTeX source of a starter template",
      "parameters": {
        "name": {
          "type": "string",
          "description": "Template name (e.g. 'article', 'beamer', 'ieee', 'article-zh')",
          "required": true,
          "enum": ["article", "article-zh", "beamer", "ieee"]
        }
      }
    }
  ],
  "dependencies": [],
  "builtin": true
}
